# Postgres connection string. Local example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atlas_matrix?schema=public"
# API port (optional, defaults to 3000)
PORT=3000

# ── Phase 2 (verification worker) ──
# Anthropic API key — owned by Atlas, NOT a personal key. Used by `npm run refresh`.
ANTHROPIC_API_KEY="sk-ant-..."
# Optional: pin the exact model string the worker uses (names change over time).
ANTHROPIC_MODEL="claude-sonnet-4-5"
